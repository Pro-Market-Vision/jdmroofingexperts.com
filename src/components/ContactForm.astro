<section class="py-16 bg-gray-light">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-2">Request a Free Estimate</h2>
    <p class="text-gray-500 text-center mb-8">Fill out the form below and a JDM Roofing specialist will get back to you shortly.</p>
    <form class="space-y-4 bg-white p-8 rounded-lg shadow-md" action="#" method="POST">
      <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <select name="service" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent text-gray-600">
        <option value="">Select Service Type</option>
        <option>Residential Roofing</option>
        <option>Commercial Roofing</option>
        <option>Roof Maintenance</option>
        <option>Roof Coatings</option>
        <option>Copper Roofing</option>
        <option>Tile Roofing</option>
        <option>Metal Roofing</option>
        <option>Skylights</option>
        <option>Other</option>
      </select>
      <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
      <button type="submit" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-yellow-700 transition-colors">SEND</button>
    </form>
  </div>
</section>
