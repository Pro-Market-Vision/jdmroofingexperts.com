---
const WEB3FORMS_KEY = "2a11d4bc-6ee7-493e-abbd-0451bb0fdc10";
const RECAPTCHA_SITE_KEY = "6Ld0WZ4sAAAAAAFfkLQAIzRo4eSIYcFiFGMdbstN";
---

<section class="py-16 bg-gray-light">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-2">Request a Free Estimate</h2>
    <p class="text-gray-500 text-center mb-8">Fill out the form below and a JDM Roofing specialist will get back to you shortly.</p>
    <form class="space-y-4 bg-white p-8 rounded-lg shadow-md" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New Contact Form - JDM Roofing Experts" />
      <input type="hidden" name="from_name" value="JDM Roofing Experts Website" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
      <input type="hidden" name="recaptcha_response" id="recaptchaResponse" />
      <input type="text" name="name" placeholder="Name" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <input type="tel" name="phone" placeholder="Phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <input type="email" name="email" placeholder="Email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent" />
      <select name="service" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent text-gray-600">
        <option value="">Select Service Type</option>
        <option>Residential Roofing</option>
        <option>Commercial Roofing</option>
        <option>Roof Maintenance</option>
        <option>Roof Coatings</option>
        <option>Copper Roofing</option>
        <option>Tile Roofing</option>
        <option>Metal Roofing</option>
        <option>Skylights</option>
        <option>Other</option>
      </select>
      <textarea name="message" placeholder="Message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent/20 focus:border-accent resize-vertical"></textarea>
      <button type="submit" id="submit-btn" class="w-full bg-accent text-white font-heading text-xl tracking-wide py-4 rounded-lg hover:bg-yellow-700 transition-colors">SEND</button>
      <div id="form-result" class="text-center text-sm mt-2 hidden"></div>
    </form>
  </div>
</section>

<script define:vars={{ RECAPTCHA_SITE_KEY }}>
  const script = document.createElement('script');
  script.src = `https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`;
  document.head.appendChild(script);

  const form = document.getElementById('contact-form');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const result = document.getElementById('form-result');
    btn.textContent = 'SENDING...';
    btn.disabled = true;
    try {
      if (window.grecaptcha) {
        const token = await window.grecaptcha.execute(RECAPTCHA_SITE_KEY, { action: 'submit' });
        document.getElementById('recaptchaResponse').value = token;
      }
      const response = await fetch('https://api.web3forms.com/submit', { method: 'POST', body: new FormData(form) });
      const data = await response.json();
      if (data.success) {
        result.textContent = 'Thank you! Your message has been sent successfully.';
        result.className = 'text-center text-sm mt-2 text-green-600';
        result.classList.remove('hidden');
        form.reset();
      } else {
        result.textContent = 'Something went wrong. Please try again or call us directly.';
        result.className = 'text-center text-sm mt-2 text-red-600';
        result.classList.remove('hidden');
      }
    } catch {
      result.textContent = 'Something went wrong. Please try again or call us directly.';
      result.className = 'text-center text-sm mt-2 text-red-600';
      result.classList.remove('hidden');
    }
    btn.textContent = 'SEND';
    btn.disabled = false;
  });
</script>
