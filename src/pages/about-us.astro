---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | JDM Roofing Repair & Installation">
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">About Us</h1>
      <p class="text-gray-300 text-lg">With over 20 years of experience, our team of skilled professionals is dedicated to providing top-quality roofing services for both residential and commercial properties.</p>
      <p class="text-accent font-heading text-xl tracking-wide mt-4">Miami, Orlando & Fort Lauderdale</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Local Roofing Contractor</h2>
        <p class="text-gray-600 leading-relaxed">We are your trusted local roofing contractor offering repairs, replacements, and new installations for homes and businesses.</p>
      </div>
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Keeping You Informed</h2>
        <p class="text-gray-600 leading-relaxed">Effective communication is key to a successful roofing project. We are committed to transparent updates throughout the work.</p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Service After the Sale</h2>
        <p class="text-gray-600 leading-relaxed">Our commitment to our customers doesn't end once the job is done. We provide ongoing maintenance and support.</p>
      </div>
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Beyond the Warranty</h2>
        <p class="text-gray-600 leading-relaxed">We extend support far beyond warranty periods, ensuring your roof remains in top condition for years to come.</p>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Fully Insured</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Free Estimates</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Satisfied Customers</h3>
        </div>
      </div>
    </div>
  </section>
</Layout>
