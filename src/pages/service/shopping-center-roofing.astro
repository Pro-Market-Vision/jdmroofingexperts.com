---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Shopping Center Roofing | JDM Roofing"
  description="Expert shopping center roofing services in South Florida. JDM Roofing provides installation, repair, and maintenance for retail properties. Call (954) 727-5425."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-28">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Shopping Center Roofing</h1>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto">Comprehensive roofing solutions for shopping centers and retail properties across South Florida. JDM Roofing delivers durable, weather-resistant systems that protect your retail investment.</p>
    </div>
  </section>

  <!-- Installation -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Installation</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Complete roof installation services designed for shopping centers and retail complexes.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">New Roof Installation</h3>
          <p class="text-gray-600 text-sm">Full-scale roof installations engineered for the large footprint and structural demands of shopping centers.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Flat Roof Systems</h3>
          <p class="text-gray-600 text-sm">TPO, EPDM, and modified bitumen flat roofing systems built for large commercial retail spaces.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Energy-Efficient Roofing</h3>
          <p class="text-gray-600 text-sm">Reflective and insulated roofing options that reduce energy costs across your shopping center.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Repair -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Repair</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Fast, reliable repairs to minimize disruption to your retail tenants and shoppers.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Leak Detection</h3>
          <p class="text-gray-600 text-sm">Advanced leak detection to identify and resolve water intrusion before it damages retail spaces.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Membrane Repair</h3>
          <p class="text-gray-600 text-sm">Expert repair of commercial roofing membranes to restore waterproofing protection.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Flashing Repair</h3>
          <p class="text-gray-600 text-sm">Precision flashing repair at HVAC units, skylights, and roof edges to prevent water penetration.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Storm Damage Repair</h3>
          <p class="text-gray-600 text-sm">Emergency storm damage repair to quickly restore your shopping center roof after severe weather.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Maintenance -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Maintenance</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Preventative maintenance programs to extend the life of your shopping center roof.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Regular Inspections</h3>
          <p class="text-gray-600 text-sm">Scheduled roof inspections to catch small issues before they become major problems for your retail tenants.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Roof Cleaning</h3>
          <p class="text-gray-600 text-sm">Professional cleaning to remove debris, algae, and buildup from your shopping center roof.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Preventative Maintenance</h3>
          <p class="text-gray-600 text-sm">Proactive maintenance programs designed to maximize roof lifespan and minimize costly repairs.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Drainage Maintenance</h3>
          <p class="text-gray-600 text-sm">Keep drainage systems clear and functional to prevent ponding water and structural damage.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Fully Insured</h3>
          <p class="text-gray-600 text-sm">Complete insurance coverage on every shopping center roofing project for your peace of mind.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Free Estimates</h3>
          <p class="text-gray-600 text-sm">Get a free, no-obligation estimate for your shopping center roofing project.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">4.9-Star Google Rating</h3>
          <p class="text-gray-600 text-sm">Our stellar reputation reflects our commitment to quality shopping center roofing services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Get a Free Shopping Center Roofing Estimate</h2>
      <p class="text-gray-300 mb-8">Contact JDM Roofing today to discuss your shopping center roofing needs.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275425" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors" aria-label="Call JDM Roofing">(954) 727-5425</a>
        <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">FREE ESTIMATE</a>
      </div>
    </div>
  </section>

  <ContactForm />
</Layout>
