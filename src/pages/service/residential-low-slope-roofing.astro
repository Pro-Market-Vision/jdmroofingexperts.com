---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Residential Low-Slope Roofing | JDM Roofing"
  description="JDM Roofing provides residential low-slope roofing installation, repair, and maintenance in Fort Lauderdale. Expert flat roof solutions. Call (954) 727-5425."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Residential Low-Slope Roofing</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">JDM Roofing specializes in residential low-slope roofing installation, repair, and maintenance throughout Fort Lauderdale and South Florida. We deliver reliable, long-lasting flat and low-slope roof solutions tailored to your home.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded-lg hover:bg-yellow-700 transition-colors">Get a Free Estimate</a>
        <a href="tel:9547275425" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded-lg hover:bg-white hover:text-primary transition-colors">(954) 727-5425</a>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Low-Slope Roofing Experts in Fort Lauderdale</h2>
        <p class="text-gray-600 leading-relaxed mb-4">Low-slope and flat roofs are common across South Florida homes, and they require specialized knowledge to install and maintain properly. Unlike steep-slope roofs, low-slope systems rely on continuous membranes, proper drainage, and quality sealants to keep water out and protect your home from the elements.</p>
        <p class="text-gray-600 leading-relaxed">At JDM Roofing, our team has extensive experience with TPO, modified bitumen, built-up roofing, and other low-slope systems. We help homeowners choose the right materials and design for their property, ensuring years of dependable performance.</p>
      </div>
      <div>
        <img src="/images/services/residential.jpg" alt="Residential low-slope roofing installation in Fort Lauderdale" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Installation Services -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Installation Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">New Roof Installation</h3>
          <p class="text-gray-600 leading-relaxed">Complete low-slope roof installation for new construction, including substrate preparation, insulation, membrane application, and drainage system setup.</p>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Custom Solutions</h3>
          <p class="text-gray-600 leading-relaxed">Tailored low-slope roofing designs for unique home architectures, including multi-level roofs, rooftop decks, and homes with mixed roof types.</p>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Energy-Efficient Options</h3>
          <p class="text-gray-600 leading-relaxed">Cool roof membranes and reflective coatings that reduce heat absorption, lower energy bills, and keep your home comfortable in South Florida's heat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Repair Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Repair Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-gray-light p-6 rounded-lg">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Leak Detection</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Advanced leak detection methods to pinpoint the source of water intrusion on your low-slope roof quickly and accurately.</p>
        </div>
        <div class="bg-gray-light p-6 rounded-lg">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Membrane Replacement</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Partial or full membrane replacement when your existing roofing membrane has deteriorated beyond repair.</p>
        </div>
        <div class="bg-gray-light p-6 rounded-lg">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Flashing Repair</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Repair and replacement of flashing around vents, edges, and penetrations to eliminate common leak points on flat roofs.</p>
        </div>
        <div class="bg-gray-light p-6 rounded-lg">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Storm Damage Repair</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Emergency and scheduled repairs for hurricane and storm damage, including wind uplift, ponding water, and debris impact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Maintenance Services -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Maintenance Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Regular Inspections</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Scheduled roof inspections to identify wear, ponding, and potential issues before they lead to leaks or structural problems.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Cleaning</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Debris removal, drain clearing, and surface cleaning to maintain proper drainage and prevent premature membrane deterioration.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Preventative Maintenance</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Proactive care including seam re-welding, edge securement checks, and minor patching to extend the life of your low-slope roof.</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Sealant Application</h3>
          <p class="text-gray-600 leading-relaxed text-sm">Professional sealant and coating application around penetrations, edges, and seams to reinforce waterproofing and UV protection.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Why Choose JDM Roofing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Fully Insured</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Free Estimates</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">4.9-Star Google Rating</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Ready to Get Started?</h2>
      <p class="text-gray-300 text-lg mb-8">Contact JDM Roofing today for a free estimate on residential low-slope roofing installation, repair, or maintenance in Fort Lauderdale.</p>
      <a href="/contact" class="inline-block bg-accent text-white font-heading text-xl tracking-wide px-10 py-4 rounded-lg hover:bg-yellow-700 transition-colors">Contact Us Today</a>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl text-center tracking-wide text-primary mb-8">Request a Free Estimate</h2>
      <ContactForm />
    </div>
  </section>
</Layout>
