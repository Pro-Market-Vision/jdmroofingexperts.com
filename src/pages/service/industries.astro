---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Industries We Serve | JDM Roofing"
  description="JDM Roofing serves multiple industries with tailored roofing solutions. Over 20 years of experience in residential, commercial, and industrial roofing across South Florida."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-28">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Industries We Serve</h1>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto">JDM Roofing serves multiple sectors with tailored roofing solutions. With over 20 years of experience, we deliver expert roofing services for every type of building across South Florida.</p>
    </div>
  </section>

  <!-- Industrial Roofing Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Industrial Roofing</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Comprehensive roofing solutions for every industrial and commercial need.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">New Roof Installation</h3>
          <p class="text-gray-600 text-sm">Complete roof installations for industrial buildings using premium materials and expert craftsmanship.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Roof Repair</h3>
          <p class="text-gray-600 text-sm">Fast, reliable roof repairs to minimize downtime and protect your operations.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Maintenance Programs</h3>
          <p class="text-gray-600 text-sm">Scheduled maintenance programs to extend your roof's lifespan and prevent costly repairs.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Custom Solutions</h3>
          <p class="text-gray-600 text-sm">Tailored roofing solutions designed to meet the unique requirements of your industry.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Specialized Services -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Specialized Services</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Beyond standard roofing, we offer specialized services to meet every need.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Skylight Installation</h3>
          <p class="text-gray-600 text-sm">Professional skylight installation to bring natural light into any building.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Green Roofing</h3>
          <p class="text-gray-600 text-sm">Eco-friendly roofing options that reduce energy costs and environmental impact.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Solar Roofing</h3>
          <p class="text-gray-600 text-sm">Solar-ready roofing systems and solar panel integration for energy savings.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Historical Restoration</h3>
          <p class="text-gray-600 text-sm">Careful restoration of historical roofs while preserving architectural integrity.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose JDM -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Why Choose JDM</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Trusted by businesses across South Florida for quality and reliability.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Expertise Across Industries</h3>
          <p class="text-gray-600 text-sm">Over 20 years of experience serving diverse industries with specialized roofing knowledge.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Quality Materials</h3>
          <p class="text-gray-600 text-sm">We use only the highest-quality roofing materials from trusted manufacturers.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Customer Satisfaction</h3>
          <p class="text-gray-600 text-sm">Our 4.9-star rating reflects our commitment to exceeding customer expectations.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <div class="w-14 h-14 bg-primary rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Competitive Pricing</h3>
          <p class="text-gray-600 text-sm">Fair, transparent pricing with no hidden fees. Free estimates on every project.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industry Cards Grid -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roofing for Every Industry</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Select your industry to learn more about our specialized roofing solutions.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <a href="/service/apartment-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Apartment Roofing</h3>
        </a>
        <a href="/service/church-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Church Roofing</h3>
        </a>
        <a href="/service/condo-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Condo Roofing</h3>
        </a>
        <a href="/service/high-rise-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">High-Rise Roofing</h3>
        </a>
        <a href="/service/office-building-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Office Building Roofing</h3>
        </a>
        <a href="/service/school-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">School Roofing</h3>
        </a>
        <a href="/service/mall-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Mall Roofing</h3>
        </a>
        <a href="/service/shopping-center-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Shopping Center Roofing</h3>
        </a>
        <a href="/service/warehouse-roofing" class="block bg-white rounded-lg p-8 shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 text-center border border-gray-border/30">
          <h3 class="font-heading text-2xl tracking-wide text-primary">Warehouse Roofing</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Ready to Start Your Roofing Project?</h2>
      <p class="text-gray-300 mb-8">Contact JDM Roofing today for a free estimate on your commercial or industrial roofing project.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275425" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors" aria-label="Call JDM Roofing">(954) 727-5425</a>
        <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">FREE ESTIMATE</a>
      </div>
    </div>
  </section>

  <ContactForm />
</Layout>
