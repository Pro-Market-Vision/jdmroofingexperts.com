---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Roof Maintenance Fort Lauderdale | JDM Roofing"
  description="Professional roof maintenance services in Fort Lauderdale. Inspections, cleaning, repairs & preventative care. Protect your investment. Call (954) 727-5425."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-24 md:py-32 overflow-hidden">
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style="background-image: url('/images/services/maintenance.jpg')" role="img" aria-label="Roof maintenance services by JDM Roofing in Fort Lauderdale"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-primary/95 to-primary/70"></div>
    <div class="relative max-w-7xl mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Roof Maintenance</h1>
        <p class="text-xl md:text-2xl font-light mb-4 text-gray-200">Serving Miami, Orlando & Fort Lauderdale</p>
        <p class="text-base md:text-lg text-gray-300 mb-8">
          JDM Roofing offers comprehensive roof maintenance programs to keep your roof in peak condition. Regular maintenance extends the life of your roof and prevents costly emergency repairs.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="/contact" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors text-center">GET A FREE ESTIMATE</a>
          <a href="tel:9547275425" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors text-center" aria-label="Call JDM Roofing">(954) 727-5425</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Service Description -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-4">Expert Roof Maintenance Services</h2>
        <p class="text-gray-600 leading-relaxed mb-4">
          South Florida's intense sun, heavy rains, and hurricane season take a toll on every roof. JDM Roofing's proactive maintenance programs help Fort Lauderdale property owners avoid unexpected failures and extend their roof's lifespan by years.
        </p>
        <p class="text-gray-600 leading-relaxed">
          Our maintenance services cover everything from thorough inspections and debris removal to moss and algae treatment and gutter cleaning. When we identify issues, our repair team addresses them promptly to prevent small problems from becoming major expenses.
        </p>
      </div>
      <div>
        <img src="/images/services/maintenance.jpg" alt="Roof maintenance service by JDM Roofing in Fort Lauderdale" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Sub-Services -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">What We Offer</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-md">
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-4">Maintenance</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Regular Inspections</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Cleaning & Debris Removal</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Moss & Algae Treatment</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Gutter Cleaning</li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-md">
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-4">Repair</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Leak Detection</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Shingle Replacement</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Flashing Repair</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Storm Damage</li>
          </ul>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-md">
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-4">Installation</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> New Roof</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Roof Replacement</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Custom Solutions</li>
            <li class="flex items-start gap-2"><span class="text-accent font-bold mt-1">&#10003;</span> Ventilation Upgrades</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose JDM -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Why Choose JDM Roofing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Experienced Professionals</h3>
          <p class="text-gray-600 text-sm">Our maintenance team knows South Florida roofs inside and out, catching problems before they escalate.</p>
        </div>
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Licensed and Insured</h3>
          <p class="text-gray-600 text-sm">Fully licensed and insured for your complete peace of mind on every maintenance visit.</p>
        </div>
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Quality Guarantee</h3>
          <p class="text-gray-600 text-sm">We stand behind our work with a quality guarantee on all maintenance and repair services.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Fully Insured</h3>
          <p class="text-gray-600 text-sm">JDM Roofing is fully insured, giving you peace of mind with every roofing project we undertake.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Free Estimates</h3>
          <p class="text-gray-600 text-sm">Get a free, no-obligation estimate for any roofing repair or installation project.</p>
        </div>
        <div class="text-center p-8 bg-white rounded-lg shadow-md">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">4.9-Star Google Rating</h3>
          <p class="text-gray-600 text-sm">Our 4.9-star Google rating reflects our dedication to excellence in every roofing project.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Get A Free Estimate</h2>
      <p class="text-gray-300 mb-8">Contact JDM Roofing today for a free estimate on your roof maintenance needs in Fort Lauderdale.</p>
      <a href="/contact" class="inline-block bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors">GET A FREE ESTIMATE</a>
    </div>
  </section>

  <!-- Contact Form -->
  <ContactForm />

</Layout>
