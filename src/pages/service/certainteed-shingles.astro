---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="CertainTeed Shingles Fort Lauderdale | JDM Roofing"
  description="JDM Roofing specializes in CertainTeed shingle installation, repair, and maintenance in Fort Lauderdale. Durable, visually appealing roofing solutions. Call (954) 727-5425."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">CertainTeed Shingles</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">JDM Roofing specializes in CertainTeed shingle installation, repair, and maintenance throughout Fort Lauderdale and South Florida. We deliver durable, visually appealing roofing solutions built to last.</p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded-lg hover:bg-yellow-700 transition-colors">Get a Free Estimate</a>
        <a href="tel:9547275425" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded-lg hover:bg-white hover:text-primary transition-colors">(954) 727-5425</a>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="font-heading text-4xl tracking-wide text-primary mb-4">Trusted CertainTeed Shingle Experts</h2>
        <p class="text-gray-600 leading-relaxed mb-4">CertainTeed has been a leader in the roofing industry for over a century, manufacturing shingles known for their durability, weather resistance, and aesthetic appeal. At JDM Roofing, we are proud to offer expert installation, repair, and maintenance of CertainTeed shingle products to homeowners across Fort Lauderdale, Miami, and Orlando.</p>
        <p class="text-gray-600 leading-relaxed">Whether you are building a new home or replacing an aging roof, CertainTeed shingles provide outstanding protection against South Florida's heat, humidity, and storms. Our trained professionals ensure every shingle is installed to manufacturer specifications for maximum performance and warranty coverage.</p>
      </div>
      <div>
        <img src="/images/services/residential.jpg" alt="CertainTeed shingle roofing installation in Fort Lauderdale" class="rounded-lg shadow-lg w-full" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Services Offered -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Our CertainTeed Shingle Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Installation</h3>
          <p class="text-gray-600 leading-relaxed">Complete CertainTeed shingle installation for new construction and full roof replacements. We handle every step from deck preparation to final inspection.</p>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Repair</h3>
          <p class="text-gray-600 leading-relaxed">Expert repair services for damaged, missing, or worn CertainTeed shingles. We restore your roof's integrity quickly and affordably after storms or general wear.</p>
        </div>
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-14 h-14 bg-accent rounded-full flex items-center justify-center mb-4">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Maintenance</h3>
          <p class="text-gray-600 leading-relaxed">Routine inspections, cleaning, and preventative maintenance to extend the life of your CertainTeed shingle roof and keep your warranty intact.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-10">Why Choose JDM Roofing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Fully Insured</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">Free Estimates</h3>
        </div>
        <div class="p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary">4.9-Star Google Rating</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Ready to Get Started?</h2>
      <p class="text-gray-300 text-lg mb-8">Contact JDM Roofing today for a free estimate on CertainTeed shingle installation, repair, or maintenance in Fort Lauderdale.</p>
      <a href="/contact" class="inline-block bg-accent text-white font-heading text-xl tracking-wide px-10 py-4 rounded-lg hover:bg-yellow-700 transition-colors">Contact Us Today</a>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl text-center tracking-wide text-primary mb-8">Request a Free Estimate</h2>
      <ContactForm />
    </div>
  </section>
</Layout>
