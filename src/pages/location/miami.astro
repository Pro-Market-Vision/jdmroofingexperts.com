---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Roofing Services Miami | JDM Roofing"
  description="Expert roofing repair & installation in Miami, FL. Over 20 years experience, residential & commercial roofing. Free estimates. Call (954) 727-5425."
>
  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-28">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <p class="text-accent font-heading text-lg tracking-wide mb-2">JDM Roofing Repair & Installation</p>
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Roofing Services in Miami</h1>
      <p class="text-gray-300 text-lg max-w-3xl mx-auto mb-4">With over 20 years of experience, our team of skilled professionals is dedicated to providing top-quality roofing services for both residential and commercial properties.</p>
      <p class="text-gray-400 mb-8">Serving Miami, Orlando & Fort Lauderdale</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275425" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors">(954) 727-5425</a>
        <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">GET A FREE ESTIMATE</a>
      </div>
    </div>
  </section>

  <!-- Comprehensive Services Intro -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-6">Comprehensive Roofing Services in Miami</h2>
      <p class="text-gray-600 text-lg leading-relaxed">JDM Roofing specializes in comprehensive roofing solutions for both residential and commercial properties in Miami, ensuring durability and aesthetic appeal for every project. From minor repairs to complete roof replacements, we have you covered.</p>
    </div>
  </section>

  <!-- Roof Installation -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Installation in Miami</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Professional new roof installation using premium materials built to withstand Miami's tropical climate.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">New Roof Installation</h3>
          <p class="text-gray-600 text-sm">Complete new roof installations using high-quality materials designed for Miami's heat and hurricane conditions.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Custom Roofing Solutions</h3>
          <p class="text-gray-600 text-sm">Tailored roofing systems designed to meet the specific needs and style of your Miami property.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Energy-Efficient Roofing</h3>
          <p class="text-gray-600 text-sm">Energy-efficient roofing options that reduce utility costs and improve comfort in Miami's heat.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roof Repair -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Repair in Miami</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Fast, reliable roof repairs for all types of roofing issues in Miami.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Leak Detection & Repair</h3>
          <p class="text-gray-600 text-sm">Advanced leak detection to identify and resolve water intrusion before it causes costly damage.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Shingle Replacement</h3>
          <p class="text-gray-600 text-sm">Expert replacement of damaged or worn shingles to restore your roof's integrity.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Flashing Repair</h3>
          <p class="text-gray-600 text-sm">Precision flashing repair around vents, chimneys, and skylights to prevent water penetration.</p>
        </div>
        <div class="text-center p-6 bg-gray-light rounded-lg">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Storm Damage Repair</h3>
          <p class="text-gray-600 text-sm">Emergency storm damage repair to quickly restore your Miami roof after hurricane season.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Roof Maintenance -->
  <section class="py-16 bg-gray-light">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide text-primary mb-2 text-center">Roof Maintenance in Miami</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">Regular maintenance is crucial for prolonging the life of your roof in Miami's tropical climate.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Regular Inspections</h3>
          <p class="text-gray-600 text-sm">Scheduled inspections to identify potential issues early before they become costly problems.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Cleaning & Debris Removal</h3>
          <p class="text-gray-600 text-sm">Professional cleaning to remove debris, algae, and buildup from your Miami roof.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Preventative Maintenance</h3>
          <p class="text-gray-600 text-sm">Proactive maintenance programs to maximize your roof's lifespan and minimize repair costs.</p>
        </div>
        <div class="text-center p-6 bg-white rounded-lg shadow-md">
          <h3 class="font-heading text-xl tracking-wide text-primary mb-2">Sealant Application</h3>
          <p class="text-gray-600 text-sm">Protective sealant application for waterproofing and extended roof durability.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Features -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Fully Insured</h3>
          <p class="text-gray-600 text-sm">JDM Roofing offers fully insured expert roofing repair and installation services in Miami.</p>
        </div>
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">Free Estimates</h3>
          <p class="text-gray-600 text-sm">JDM Roofing provides top-notch expert roofing repair and installation services with free estimates in Miami.</p>
        </div>
        <div class="text-center p-8 bg-gray-light rounded-lg">
          <div class="w-16 h-16 bg-accent rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </div>
          <h3 class="font-heading text-2xl tracking-wide text-primary mb-2">4.9-Star Google Rating</h3>
          <p class="text-gray-600 text-sm">Our stellar reputation reflects our commitment to quality roofing services in Miami.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-primary text-white text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Get a Free Roofing Estimate in Miami</h2>
      <p class="text-gray-300 mb-8">Contact JDM Roofing today for a free consultation on your Miami roofing project.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275425" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors">(954) 727-5425</a>
        <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">FREE ESTIMATE</a>
      </div>
    </div>
  </section>

  <ContactForm />
</Layout>
