---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Roofing Blog | JDM Roofing Experts Fort Lauderdale"
  description="Expert roofing tips, guides, and insights from JDM Roofing in Fort Lauderdale. Learn about roof replacement costs, best materials for Florida, and when to replace your roof."
>

  <!-- Hero -->
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Roofing Blog</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">Expert roofing tips, cost guides, and insights from JDM Roofing in Fort Lauderdale. Stay informed about protecting your home or business.</p>
    </div>
  </section>

  <!-- Blog Posts -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <a href="/blog/roof-replacement-cost-fort-lauderdale" class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30">
          <div class="aspect-[4/3] overflow-hidden bg-primary/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div class="p-6">
            <p class="text-accent text-xs font-heading tracking-wide mb-2">COST GUIDE</p>
            <h2 class="font-heading text-xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">How Much Does Roof Replacement Cost in Fort Lauderdale?</h2>
            <p class="text-gray-600 text-sm leading-relaxed">A comprehensive 2025 guide to roof replacement costs in Fort Lauderdale, including material breakdowns and factors that affect pricing.</p>
          </div>
        </a>

        <a href="/blog/best-roofing-materials-florida" class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30">
          <div class="aspect-[4/3] overflow-hidden bg-primary/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
          </div>
          <div class="p-6">
            <p class="text-accent text-xs font-heading tracking-wide mb-2">MATERIALS GUIDE</p>
            <h2 class="font-heading text-xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">Best Roofing Materials for Florida Homes</h2>
            <p class="text-gray-600 text-sm leading-relaxed">A complete guide to choosing the best roofing materials for Florida's climate, including metal, tile, and shingle options.</p>
          </div>
        </a>

        <a href="/blog/signs-you-need-new-roof" class="group bg-white rounded-lg overflow-hidden shadow-md hover:shadow-2xl hover:-translate-y-2 transition-all duration-300 border border-gray-border/30">
          <div class="aspect-[4/3] overflow-hidden bg-primary/10 flex items-center justify-center">
            <svg class="w-16 h-16 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
          </div>
          <div class="p-6">
            <p class="text-accent text-xs font-heading tracking-wide mb-2">HOMEOWNER TIPS</p>
            <h2 class="font-heading text-xl tracking-wide text-primary mb-2 group-hover:text-accent transition-colors">8 Signs You Need a New Roof in South Florida</h2>
            <p class="text-gray-600 text-sm leading-relaxed">Learn the warning signs that indicate your roof needs replacement, from age and leaks to storm damage and energy costs.</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 text-white text-center overflow-hidden">
    <div class="absolute inset-0 bg-primary"></div>
    <div class="relative max-w-3xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl tracking-wide mb-4">Need Expert Roofing Advice?</h2>
      <p class="text-gray-300 mb-8">Contact JDM Roofing for a free inspection and personalized recommendation for your Fort Lauderdale property.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:9547275425" class="bg-accent text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-yellow-700 transition-colors">(954) 727-5425</a>
        <a href="/contact" class="border-2 border-white text-white font-heading text-xl tracking-wide px-8 py-4 rounded hover:bg-white hover:text-primary transition-colors">FREE ESTIMATE</a>
      </div>
    </div>
  </section>
</Layout>
