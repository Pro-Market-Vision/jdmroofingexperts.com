---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
  { src: "/images/gallery/Residential-Roofing.webp", alt: "Residential Roofing" },
  { src: "/images/gallery/Commercial-Roofing.webp", alt: "Commercial Roofing" },
  { src: "/images/gallery/Roof-Coatings.webp", alt: "Roof Coatings" },
  { src: "/images/gallery/Expert-Residential-Roofing.webp", alt: "Expert Residential Roofing" },
  { src: "/images/gallery/Copper-Roofing.webp", alt: "Copper Roofing" },
  { src: "/images/gallery/Tile-Roofing.webp", alt: "Tile Roofing" },
  { src: "/images/gallery/Metal-Roofing-jdm-repair.webp", alt: "Metal Roofing" },
  { src: "/images/gallery/Skylights.webp", alt: "Skylights" },
  { src: "/images/gallery/Industries.webp", alt: "Industries" },
  { src: "/images/gallery/Apartment-Roofing.webp", alt: "Apartment Roofing" },
  { src: "/images/gallery/Church-Roofing-by-JDM.webp", alt: "Church Roofing" },
  { src: "/images/gallery/Office-Building-Roofing.webp", alt: "Office Building Roofing" },
];
---

<Layout title="Gallery | JDM Roofing Repair & Installation">
  <section class="relative bg-primary text-white py-20 md:py-24">
    <div class="relative max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-heading text-5xl md:text-7xl tracking-wide mb-4">Gallery</h1>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto">
        At JDM Roofing Repair And Installation, we pride ourselves on being the premier local roofing contractor in your area. With over 20 years of experience.
      </p>
      <p class="text-accent font-heading text-xl tracking-wide mt-4">Miami, Orlando & Fort Lauderdale</p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-heading text-4xl md:text-5xl text-center tracking-wide text-primary mb-2">Our Recent Works</h2>
      <p class="text-gray-500 text-center mb-10 max-w-2xl mx-auto">
        JDM Roofing Repair and Installation prides itself on delivering exceptional roofing solutions. Check out our Gallery to see our top-quality installations and repairs.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {galleryImages.map((img) => (
          <div class="aspect-square overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow">
            <img src={img.src} alt={img.alt} class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
