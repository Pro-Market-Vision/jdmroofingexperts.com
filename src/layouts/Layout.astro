---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
}

const { title, description = "JDM Roofing Repair & Installation — expert roofing services in Fort Lauderdale, Miami & Orlando. Residential & commercial. Free estimates. Call (954) 727-5425.", keywords = "roofing repair Fort Lauderdale, roof installation, commercial roofing, residential roofing, metal roofing, tile roofing, roof replacement, Miami roofing, Orlando roofing, South Florida roofer" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link rel="alternate" hreflang="en" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content="JDM Roofing Repair & Installation" />
    <meta property="og:image" content={new URL('/images/logo.png', Astro.site).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/images/logo.png', Astro.site).href} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "RoofingContractor",
      "name": "JDM Roofing Repair & Installation",
      "description": "Expert roofing repair, installation, and maintenance services in Fort Lauderdale, Miami, and Orlando. Residential and commercial roofing.",
      "url": "https://jdmroofingexperts.com",
      "telephone": "+1-954-727-5425",
      "image": "https://jdmroofingexperts.com/images/logo.png",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "721 NE 3rd Ave Unit D",
        "addressLocality": "Fort Lauderdale",
        "addressRegion": "FL",
        "postalCode": "33304",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 26.1224,
        "longitude": -80.1373
      },
      "areaServed": [
        { "@type": "City", "name": "Fort Lauderdale" },
        { "@type": "City", "name": "Miami" },
        { "@type": "City", "name": "Orlando" }
      ],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "120",
        "bestRating": "5"
      },
      "sameAs": []
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://jdmroofingexperts.com/"
        }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "serviceType": "Roofing Services",
      "provider": {
        "@type": "RoofingContractor",
        "name": "JDM Roofing Repair & Installation",
        "url": "https://jdmroofingexperts.com"
      },
      "areaServed": [
        { "@type": "City", "name": "Fort Lauderdale" },
        { "@type": "City", "name": "Miami" },
        { "@type": "City", "name": "Orlando" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Roofing Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Residential Roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Commercial Roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Metal Roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tile Roofing" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Coatings" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Skylights" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Maintenance" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Copper Roofing" } }
        ]
      }
    })} />
  </head>
  <body class="font-body text-gray-800 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
